{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "customManagers:dockerfileVersions"
  ],
  "dependencyDashboard": true,
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "description": "Terraform providers and version in the root versions.tf",
      "ignorePaths": ["**/modules/**", "**/examples/**"]
      "rangeStrategy": "bump",
      "matchManagers": ["terraform"],
      "matchDepTypes": ["required_provider", "required_version"],
      "groupName": "Terraform Providers",
      "groupSlug": "tf-providers",
      "labels": ["ok-to-test"],
      "commitMessagePrefix": "chore(deps): ",
      "automerge": false
    },
    {
      "description": "Group GitHub Actions updates to avoid many CI pull requests",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions Dependencies",
      "groupSlug": "gh-actions",
      "automerge": false
    },
    {
      "description": "Terraform modules grouped by source",
      "matchManagers": ["terraform"],
      "matchDepTypes": ["module"],
      "groupName": "Terraform Modules",
      "groupSlug": "tf-modules",
      "labels": ["ok-to-test"],
      "commitMessagePrefix": "chore(deps): ",
      "automerge": false
    }
  ]
}
